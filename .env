# ============================================================
# WebPilot AI – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Application ────────────────────────────────────────────
APP_NAME=WebPilot AI
APP_ENV=development          # development | staging | production
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://webpilot:webpilot_pass@postgres:5432/webpilot_db
# For local development without Docker:
# DATABASE_URL=postgresql+asyncpg://webpilot:webpilot_pass@localhost:5432/webpilot_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── AI Provider ────────────────────────────────────────────
AI_PROVIDER=gemini               # gemini | openai
GEMINI_API_KEY=AQ.Ab8RN6J99dQie3yBrSJksVj0qIUS6MVPLme9qqLlTqyiatxM5A
GEMINI_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=                  # optional – only if AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o

# ─── Browser ────────────────────────────────────────────────
BROWSER_TYPE=chromium            # chromium | firefox | edge
BROWSER_HEADLESS=true
BROWSER_SCREENSHOT_INTERVAL=500  # ms between live preview frames
BROWSER_DEFAULT_TIMEOUT=30000    # ms
BROWSER_SLOW_MO=50               # ms between actions (human-like)

# ─── Storage Paths ──────────────────────────────────────────
SCREENSHOTS_DIR=/app/screenshots
DOWNLOADS_DIR=/app/downloads
REPORTS_DIR=/app/reports
LOGS_DIR=/app/logs

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173","http://127.0.0.1"]

# ─── Retry / Recovery ───────────────────────────────────────
MAX_RETRY_COUNT=3
RECOVERY_TIMEOUT=10000           # ms

# ─── Frontend ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_APP_NAME=WebPilot AI
